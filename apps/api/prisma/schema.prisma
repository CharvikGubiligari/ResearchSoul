generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrgRole {
  OWNER
  MEMBER
  VIEWER
}

enum UsageEventType {
  LLM_TOKENS
  RETRIEVAL_CALL
  STORAGE_BYTES
  RESEARCH_RUN
}

enum ResearchType {
  MARKET_ANALYSIS
  COMPETITIVE_INTEL
  INVESTMENT_MEMO
  TECHNICAL_REVIEW
  LEGAL_REGULATORY
  CUSTOM
}

enum ResearchDepth {
  QUICK_SCAN
  STANDARD
  DEEP_DIVE
}

enum ResearchOutputType {
  EXECUTIVE_SUMMARY
  DEEP_REPORT
  INVESTMENT_MEMO
  MARKET_REPORT
  TECHNICAL_REVIEW
  SWOT
  PESTLE
  PORTER_FIVE_FORCES
  COMPETITIVE_MATRIX
  LANDSCAPE_ANALYSIS
}

enum ResearchPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum ResearchStatus {
  DRAFT
  PENDING
  PLANNING
  RUNNING
  SYNTHESIZING
  COMPLETED
  FAILED
  CANCELLED
  PAUSED
}

enum ExecutionStatus {
  PENDING
  PLANNING
  RUNNING
  SYNTHESIZING
  COMPLETED
  FAILED
  CANCELLED
  PAUSED
}

enum TaskStatus {
  PENDING
  READY
  RUNNING
  COMPLETED
  FAILED
  SKIPPED
  CANCELLED
}

enum AgentType {
  MARKET
  COMPETITOR
  FUNDING
  CUSTOMER
  TECHNOLOGY
  PATENT
  ACADEMIC
  NEWS
  FINANCIAL
  PRODUCT
  LEGAL
  TREND
}

enum AgentRunStatus {
  REGISTERED
  IDLE
  RUNNING
  COMPLETED
  FAILED
}

enum SourceType {
  GOOGLE
  BING
  NEWS
  ARXIV
  PUBMED
  REDDIT
  GITHUB
  CRUNCHBASE
  SEC
  WIKIPEDIA
  BLOG
  RSS
  YOUTUBE
  PODCAST
  WHITEPAPER
  BOOK
  INTERNAL_DOC
  PDF
  CSV
  EXCEL
  COMPANY_WEBSITE
  PATENT_DB
}

enum DocumentType {
  WEB
  NEWS
  PAPER
  FILING
  SOCIAL
  CODE
  PATENT
  VIDEO
  PODCAST
  BOOK
  INTERNAL
  SPREADSHEET
  PDF
  OTHER
}

enum VerificationStatus {
  VERIFIED
  DISPUTED
  UNVERIFIED
  STALE
}

enum CitationStyle {
  APA
  MLA
  CHICAGO
  IEEE
  BLUEBOOK
}

enum CitationMode {
  INLINE
  FOOTNOTE
  ENDNOTE
}

enum EntityType {
  COMPANY
  PERSON
  PRODUCT
  MARKET
  TECHNOLOGY
  INVESTOR
  COUNTRY
  REGULATION
}

enum ReportFormat {
  PDF
  MARKDOWN
  DOCX
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  name         String?
  googleId     String?  @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships OrganizationMember[]
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  credits   Decimal  @default(1000) @db.Decimal(12, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members     OrganizationMember[]
  workspaces  Workspace[]
  usageEvents UsageEvent[]
}

model OrganizationMember {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  role           OrgRole  @default(MEMBER)
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
}

model Workspace {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  slug           String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  projects     Project[]

  @@unique([organizationId, slug])
  @@index([organizationId])
}

model Project {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  research  Research[]

  @@index([workspaceId])
}

model UsageEvent {
  id             String         @id @default(cuid())
  organizationId String
  type           UsageEventType
  amount         Decimal        @db.Decimal(12, 4)
  metadata       Json?
  createdAt      DateTime       @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
}

// ─── Research pipeline (PDF data model) ───────────────────

model Research {
  id                 String             @id @default(cuid())
  projectId          String
  objective          String
  researchType       ResearchType       @default(MARKET_ANALYSIS)
  depth              ResearchDepth      @default(STANDARD)
  budget             Decimal?           @db.Decimal(12, 2)
  spent              Decimal            @default(0) @db.Decimal(12, 4)
  deadline           DateTime?
  language           String             @default("en")
  country            String?
  audience           String?
  outputType         ResearchOutputType @default(DEEP_REPORT)
  customInstructions String?
  priority           ResearchPriority   @default(NORMAL)
  citationStyle      CitationStyle      @default(APA)
  citationMode       CitationMode       @default(INLINE)
  status             ResearchStatus     @default(PENDING)
  progress           Int                @default(0)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  completedAt        DateTime?

  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  executions Execution[]
  sources    Source[]
  documents  Document[]
  claims     Claim[]
  reports    Report[]
  entities   Entity[]

  @@index([projectId, status])
}

model Execution {
  id          String          @id @default(cuid())
  researchId  String
  status      ExecutionStatus @default(PENDING)
  dag         Json?
  checkpoint  Json?
  progress    Int             @default(0)
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  research  Research    @relation(fields: [researchId], references: [id], onDelete: Cascade)
  tasks     Task[]
  agentRuns AgentRun[]

  @@index([researchId])
}

model Task {
  id             String     @id @default(cuid())
  executionId    String
  nodeId         String
  question       String
  subQuestion    String?
  agentType      AgentType
  sourceTypes    SourceType[]
  expectedOutput String?
  dependencies   String[]
  status         TaskStatus @default(PENDING)
  retryCount     Int        @default(0)
  maxRetries     Int        @default(3)
  timeoutMs      Int        @default(300000)
  result         Json?
  error          String?
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime   @default(now())

  execution Execution  @relation(fields: [executionId], references: [id], onDelete: Cascade)
  agentRuns AgentRun[]

  @@index([executionId, status])
}

model AgentRun {
  id          String         @id @default(cuid())
  executionId String
  taskId      String
  agentType   AgentType
  status      AgentRunStatus @default(REGISTERED)
  health      String         @default("healthy")
  state       Json?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime       @default(now())

  execution Execution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  task      Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([executionId])
  @@index([taskId])
}

model Source {
  id         String     @id @default(cuid())
  researchId String
  sourceType SourceType
  url        String?
  title      String?
  rawContent String?    @db.Text
  s3Key      String?
  metadata   Json?
  fetchedAt  DateTime   @default(now())

  research  Research   @relation(fields: [researchId], references: [id], onDelete: Cascade)
  documents Document[]

  @@index([researchId])
}

model Document {
  id           String       @id @default(cuid())
  researchId   String
  sourceId     String?
  title        String?
  author       String?
  publisher    String?
  publishedAt  DateTime?
  documentType DocumentType @default(WEB)
  language     String?
  url          String?
  content      String       @db.Text
  license      String?
  reliability  Float        @default(0.5)
  s3Key        String?
  createdAt    DateTime     @default(now())

  research Research   @relation(fields: [researchId], references: [id], onDelete: Cascade)
  source   Source?    @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  claims   Claim[]
  evidence Evidence[]

  @@index([researchId])
}

model Claim {
  id                 String             @id @default(cuid())
  researchId         String
  documentId         String?
  text               String             @db.Text
  span               String?
  confidence         Float              @default(0)
  verificationStatus VerificationStatus @default(UNVERIFIED)
  createdAt          DateTime           @default(now())

  research       Research        @relation(fields: [researchId], references: [id], onDelete: Cascade)
  document       Document?       @relation(fields: [documentId], references: [id], onDelete: SetNull)
  evidence       Evidence[]
  contradictions Contradiction[] @relation("ClaimA")
  contradictedBy Contradiction[] @relation("ClaimB")
  entities       EntityOnClaim[]

  @@index([researchId])
}

model Evidence {
  id         String   @id @default(cuid())
  claimId    String
  documentId String
  span       String?
  excerpt    String   @db.Text
  citation   String?
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())

  claim    Claim    @relation(fields: [claimId], references: [id], onDelete: Cascade)
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([claimId])
}

model Contradiction {
  id                    String   @id @default(cuid())
  claimAId              String
  claimBId              String
  reason                String   @db.Text
  alternativeViewpoints String[]
  adjustedConfidence    Float    @default(0.5)
  createdAt             DateTime @default(now())

  claimA Claim @relation("ClaimA", fields: [claimAId], references: [id], onDelete: Cascade)
  claimB Claim @relation("ClaimB", fields: [claimBId], references: [id], onDelete: Cascade)

  @@index([claimAId])
  @@index([claimBId])
}

model Entity {
  id           String     @id @default(cuid())
  researchId   String
  name         String
  canonicalName String
  entityType   EntityType
  aliases      String[]
  metadata     Json?
  createdAt    DateTime   @default(now())

  research Research        @relation(fields: [researchId], references: [id], onDelete: Cascade)
  claims   EntityOnClaim[]

  @@index([researchId])
  @@index([canonicalName])
}

model EntityOnClaim {
  claimId  String
  entityId String

  claim  Claim  @relation(fields: [claimId], references: [id], onDelete: Cascade)
  entity Entity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@id([claimId, entityId])
}

model Report {
  id                String             @id @default(cuid())
  researchId        String
  title             String
  outputType        ResearchOutputType
  format            ReportFormat       @default(MARKDOWN)
  executiveSummary  String?            @db.Text
  content           String             @db.Text
  bibliography      String[]
  s3Key             String?
  metadata          Json?
  createdAt         DateTime           @default(now())

  research Research @relation(fields: [researchId], references: [id], onDelete: Cascade)

  @@index([researchId])
}

model PromptTemplateRecord {
  id        String   @id @default(cuid())
  name      String
  version   Int      @default(1)
  content   String   @db.Text
  category  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@unique([name, version])
  @@index([name, isActive])
}
